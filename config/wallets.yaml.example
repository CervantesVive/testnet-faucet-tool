# Custodian Faucet Wallet Configuration (LOCAL USE ONLY)
# This file contains sensitive key material and must NEVER be committed to git.
#
# Encryption workflow (for local backup):
#   1. Generate age key: age-keygen -o ~/.age/Custodian-faucet.key
#   2. Encrypt:          sops --encrypt --age $(cat ~/.age/Custodian-faucet.key | grep "public key" | cut -d: -f2) wallets.yaml > wallets.yaml.enc
#   3. Store the .enc file locally (outside the repo) or in a password manager.
#   4. To decrypt:       sops --decrypt wallets.yaml.enc > wallets.yaml
#
# Both wallets.yaml and wallets.yaml.enc are gitignored.

# Shared HD wallet mnemonic for EVM, Cosmos, UTXO chains
hd_mnemonic: "your twelve word mnemonic phrase goes here do not use this example"

# Chain-specific keypairs (for non-HD chains)
solana_private_key: "base58-encoded-private-key"
near_private_key: "ed25519:base58-encoded-key"
sui_private_key: "base64-encoded-key"
aptos_private_key: "hex-encoded-key"

# Age public key used to encrypt this file
age_public_key: "age1..."
